[
  {
    "type": "createSymlink",
    "path": "$PROJECT/.agents/skills/web-search",
    "target": "$PACK/skills/web-search"
  },
  {
    "type": "mergeJson",
    "path": "$PROJECT/.kimi-code/mcp.json",
    "pointer": "/mcpServers/service",
    "value": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@example/service-server"
      ],
      "env": {
        "MODE": "readonly",
        "TOKEN": "${SERVICE_TOKEN}"
      },
      "passEnv": [
        "HOME"
      ]
    }
  }
]
